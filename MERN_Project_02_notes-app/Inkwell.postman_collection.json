{
  "info": {
    "name": "Inkwell Notes API",
    "description": "Complete REST API collection for the Inkwell MERN Notes App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (json.token) pm.collectionVariables.set('token', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        }, 
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();", 
            "if (json.token) pm.collectionVariables.set('token', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/notes?category=Work&search=&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["notes"],
              "query": [
                { "key": "category", "value": "Work",  "description": "Filter by category" },
                { "key": "search",   "value": "",       "description": "Search term" },
                { "key": "page",     "value": "1" },
                { "key": "limit",    "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Note",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (json._id) pm.collectionVariables.set('note_id', json._id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notes",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My first note\",\n  \"content\": \"This is the note content. Write anything here.\",\n  \"category\": \"Personal\",\n  \"color\": \"amber\",\n  \"isPinned\": false\n}"
            }
          }
        },
        {
          "name": "Get Note by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notes/{{note_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/notes/{{note_id}}",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"content\": \"Updated content goes here.\",\n  \"category\": \"Work\",\n  \"color\": \"sky\",\n  \"isPinned\": true\n}"
            }
          }
        },
        {
          "name": "Toggle Pin",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/notes/{{note_id}}/pin",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/notes/{{note_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    }
  ]
}
